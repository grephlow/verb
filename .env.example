# URL the Next.js server uses to reach Directus.
# Local dev (Directus running on the host): http://localhost:8055
# docker compose (services on the same network): http://directus:8055
DIRECTUS_URL=http://localhost:8055

# Overrides for docker-compose.yml's directus service (production/"enterprise").
# Leave unset to use the bundled dev defaults.
# DIRECTUS_PUBLIC_URL=https://cms.example.com
# DIRECTUS_KEY=
# DIRECTUS_SECRET=
# DIRECTUS_ADMIN_EMAIL=
# DIRECTUS_ADMIN_PASSWORD=
