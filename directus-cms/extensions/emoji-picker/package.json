{
	"name": "emoji-picker",
	"description": "Text field with a visual picker for choosing any emoji",
	"icon": "mood",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-interface"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
