HOST="0.0.0.0"
PORT="8055"
PUBLIC_URL="http://localhost:8055"

# Generate fresh values for real deployments, e.g. `npx uuid`
KEY="generate-a-uuid"
SECRET="generate-a-uuid"

DB_CLIENT="sqlite3"
